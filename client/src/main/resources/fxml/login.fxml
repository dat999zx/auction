<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1280.0" styleClass="login-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.LoginController">

    <children>

        <Pane layoutX="384.0" layoutY="162.0" prefHeight="448.0" prefWidth="468.0" styleClass="login-card">
         <children>
      
                                <Label layoutX="41.0" layoutY="26.0" styleClass="card-title" text="Welcome Back" />
      
              <Label layoutX="41.0" layoutY="72.0" prefHeight="17.0" prefWidth="315.0" styleClass="card-subtitle" text="Access your curated auction dashboard." />
            <Label fx:id="messageLabel" alignment="CENTER" layoutX="66.0" layoutY="280.0" prefHeight="23.0" prefWidth="336.0" styleClass="field-label" text="-">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
      
              <Hyperlink layoutX="41.0" layoutY="381.0" prefHeight="23.0" prefWidth="120.0" styleClass="secondary-link" text="Forgot password?" />
         </children></Pane>
        <Label alignment="CENTER" layoutX="533.0" layoutY="72.0" prefHeight="17.0" prefWidth="167.0" styleClass="brand-title" text="Bidify" />

                    <Label alignment="CENTER" layoutX="529.0" layoutY="118.0" prefHeight="17.0" prefWidth="179.0" styleClass="brand-subtitle" text="The Precision Curator" />

                          <Label layoutX="424.0" layoutY="276.0" prefHeight="23.0" prefWidth="156.0" styleClass="field-label" text="Email or Username">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

        <TextField fx:id="usernameField" layoutX="424.0" layoutY="302.0" prefHeight="48.0" prefWidth="384.0" promptText="Enter your credentials" styleClass="text-input" />

        <Label layoutX="424.0" layoutY="372.0" prefHeight="20.0" prefWidth="85.0" styleClass="field-label" text="Password">
         <font>
            <Font size="14.0" />
         </font></Label>

                          <Button layoutX="424.0" layoutY="489.0" onAction="#handleLogin" prefHeight="50.0" prefWidth="384.0" styleClass="primary-button" text="Sign In" />

        <Label alignment="CENTER" layoutX="480.0" layoutY="644.0" prefHeight="26.0" prefWidth="278.0" styleClass="footer-text" text="New to Bidify?">
         <font>
            <Font size="14.0" />
         </font></Label>

        <Hyperlink alignment="CENTER" layoutX="569.0" layoutY="664.0" onAction="#toRegister" prefHeight="30.0" prefWidth="100.0" styleClass="footer-link" text="Register">
