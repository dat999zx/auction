            <Font size="14.0" />
         </font></Hyperlink>
      <TextField fx:id="passwordFieldVisible" layoutX="424.0" layoutY="395.0" prefHeight="48.0" prefWidth="384.0" promptText="Password" styleClass="text-input" />

              <PasswordField fx:id="passwordField" layoutX="424.0" layoutY="395.0" prefHeight="48.0" prefWidth="384.0" promptText="••••••••" styleClass="text-input" />
      <ImageView fx:id="eyeOpen" fitHeight="42.0" fitWidth="30.0" layoutX="767.0" layoutY="404.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../images/eye-open.png" />
         </image>
      </ImageView>
      <ImageView fx:id="eyeClose" fitHeight="30.0" fitWidth="30.0" layoutX="767.0" layoutY="404.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../images/eye-close.png" />
         </image>
      </ImageView>
      <Button layoutX="756.0" layoutY="394.0" onAction="#toggletext" opacity="0.0" prefHeight="50.0" prefWidth="52.0" />
    </children>
   <stylesheets>
      <URL value="@login.css" />
      <URL value="@../css/login.css" />
   </stylesheets>
