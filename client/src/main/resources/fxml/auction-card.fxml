<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxWidth="460.0" minWidth="460.0" onMouseClicked="#openAuction" prefWidth="460.0" styleClass="card-darken" stylesheets="@../css/hub.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.AuctionCardController">
    <children>
        <VBox maxWidth="460.0" minWidth="460.0" prefWidth="460.0" styleClass="auction-card" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <StackPane prefHeight="250.0" styleClass="card-image-wrap">
                    <children>
                        <ImageView fx:id="auctionImageView" fitHeight="250.0" fitWidth="460.0" preserveRatio="true" styleClass="card-image-view" />

                        <Label fx:id="statusPill" maxWidth="-Infinity" styleClass="status-pill" text="LIVE" StackPane.alignment="TOP_LEFT">
                            <StackPane.margin>
                                <Insets left="16.0" top="16.0" />
                            </StackPane.margin>
                        </Label>

                        <Label fx:id="lotPill" maxWidth="-Infinity" styleClass="lot-pill" text="Auction" StackPane.alignment="BOTTOM_LEFT">
                            <StackPane.margin>
                                <Insets bottom="16.0" left="16.0" />
                            </StackPane.margin>
                        </Label>
                    </children>
                </StackPane>

                <VBox spacing="12.0" styleClass="card-body">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <Label fx:id="title" styleClass="card-title" text="Untitled auction" wrapText="true" />
                        <Label fx:id="subtitle" styleClass="card-subtitle" text="No description." wrapText="true" />

                        <HBox styleClass="bid-panel">
                            <padding>
                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                            </padding>
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-label" text="CURRENT BID" />
                                        <Label fx:id="currentBidValue" styleClass="price-text" text="\$0.00" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <VBox alignment="CENTER_RIGHT" spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-label" text="LATEST BIDDER" />
                                        <Label fx:id="currentBidder" styleClass="meta-value" text="currentBidder" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label fx:id="sellerLabel" styleClass="card-subtitle" text="Seller: Unknown" />
                        <FlowPane fx:id="liveStatsRow" hgap="8.0" vgap="8.0">
                            <children>
                                <Label fx:id="watcherCountLabel" styleClass="stat-pill" text="0 watching" />
                                <Label fx:id="activeBidderCountLabel" styleClass="stat-pill" text="0 active bidders" />
                            </children>
                        </FlowPane>
                  <HBox>
                     <children>
                                <Label styleClass="timer-icon" text="Time left: " />
                                <Label fx:id="timerText" styleClass="timer-text" text="00:00:00" />
                     </children>
                  </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
