<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxWidth="460.0" minWidth="460.0" onMouseClicked="#openAuction" prefWidth="460.0" stylesheets="@../css/hub.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.AuctionCardController">
    <children>
        <VBox maxWidth="460.0" minWidth="460.0" prefWidth="460.0" styleClass="auction-card" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <StackPane prefHeight="250.0" styleClass="card-image-wrap">
                    <children>
                        <HBox alignment="CENTER" spacing="6.0" styleClass="timer-pill" StackPane.alignment="TOP_RIGHT">
                            <StackPane.margin>
                                <Insets right="16.0" top="16.0" />
                            </StackPane.margin>
                        </HBox>

                        <Label fx:id="lotPill" styleClass="lot-pill" text="Auction" StackPane.alignment="BOTTOM_LEFT">
                            <StackPane.margin>
                                <Insets bottom="16.0" left="16.0" />
                            </StackPane.margin>
                        </Label>
                    </children>
                </StackPane>

                <VBox spacing="12.0" styleClass="card-body">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <Label fx:id="title" styleClass="card-title" text="Untitled auction" wrapText="true" />
                        <Label fx:id="subtitle" styleClass="card-subtitle" text="No description." wrapText="true" />

                        <HBox styleClass="bid-panel">
                            <padding>
                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                            </padding>
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-label" text="CURRENT BID" />
                                        <Label fx:id="currentBidValue" styleClass="price-text" text="\$0.00" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <VBox alignment="CENTER_RIGHT" spacing="4.0">
                                    <children>
                                        <Label styleClass="meta-label" text="BIDDERS" />
                                        <Label fx:id="bidCountValue" styleClass="meta-value" text="0" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label fx:id="sellerLabel" styleClass="card-subtitle" text="Seller: Unknown" />
                  <HBox>
                     <children>
                                <Label styleClass="timer-icon" text="Time left: " />
                                <Label fx:id="timerText" styleClass="timer-text" text="00:00:00" />
                     </children>
                  </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
