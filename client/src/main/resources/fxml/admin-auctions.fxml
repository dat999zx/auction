<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bidify.controller.AdminAuctionsController"
            fitToWidth="true" fitToHeight="true" pannable="true"
            prefWidth="1080" prefHeight="720" styleClass="page-scroll">
    <content>
        <VBox styleClass="admin-auctions-page" spacing="28" prefWidth="1080" prefHeight="720">
            <padding>
                <Insets top="32" right="32" bottom="32" left="32"/>
            </padding>

            <HBox alignment="BOTTOM_LEFT" spacing="20">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <ImageView fitHeight="72" fitWidth="72" preserveRatio="true" smooth="true">
                        <image>
                            <Image url="@../images/bidify-logo-header.png"/>
                        </image>
                    </ImageView>
                    <Label text="Auction Management" styleClass="page-title"/>
                    <Label text="Review user auctions and resolve auctions that need admin action." styleClass="muted-text"/>
                </VBox>
                <Button onAction="#handleRefresh" text="Refresh" styleClass="primary-button"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="filter-bar">
                <TextField fx:id="searchField" onAction="#handleFilterChanged" promptText="Search by auction, seller, bidder, or category" HBox.hgrow="ALWAYS" styleClass="admin-search-field"/>
                <ComboBox fx:id="statusFilter" onAction="#handleFilterChanged" prefWidth="220" styleClass="admin-combo-box"/>
            </HBox>

            <VBox styleClass="admin-card" spacing="0">
                <HBox alignment="CENTER_LEFT" styleClass="admin-card-header" spacing="16">
                    <Label text="All Auctions" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="summaryLabel" text="Loading auctions..." styleClass="muted-text"/>
                </HBox>

                <VBox fx:id="auctionsContainer" styleClass="admin-auction-list" spacing="12"/>
            </VBox>

            <HBox alignment="CENTER_LEFT" styleClass="footer" spacing="24">
                <Label text="Admin actions are validated on the server before state changes are applied." HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
