<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<HBox alignment="CENTER_LEFT" spacing="24.0" styleClass="top-bar" stylesheets="@../../css/hub.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.SharedTopBarController">
    <padding>
        <Insets bottom="16.0" left="32.0" right="32.0" top="16.0" />
    </padding>

    <Button fx:id="exploreButton" styleClass="ghost-nav-button" text="☰ Explore" />

    <Region HBox.hgrow="ALWAYS" />

    <HBox fx:id="searchContainer" alignment="CENTER_LEFT" maxWidth="420.0" prefHeight="46.0" prefWidth="331.0" spacing="8.0" styleClass="search-bar">
        <Label styleClass="search-icon" text="⌕" />
        <TextField fx:id="searchBar" promptText="Search auctions, brands, or categories..." styleClass="search-field" />
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER_LEFT" spacing="24.0">
        <HBox alignment="CENTER_LEFT" spacing="18.0">
            <Button fx:id="auctionsButton" styleClass="top-link" text="Auctions" />
            <Button fx:id="createAuctionButton" styleClass="top-link" text="Create Auction" />
            <Button fx:id="logoutLinkButton" managed="false" styleClass="top-link" text="Logout" visible="false" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Button fx:id="logoutButton" styleClass="ghost-nav-button" text="Logout" />
            <Button styleClass="icon-button" text="🔔" />
            <Button styleClass="icon-button" text="⟲" />
            <StackPane prefHeight="40.0" prefWidth="40.0" styleClass="avatar-circle">
                <Label fx:id="avatarText" styleClass="avatar-text" text="U" />
            </StackPane>
        </HBox>
    </HBox>
</HBox>
