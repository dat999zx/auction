<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane pickOnBounds="false" stylesheets="@../../css/hub.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.MissionBarController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="24.0" styleClass="top-bar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="16.0" left="32.0" right="32.0" top="16.0" />
            </padding>

            <Button fx:id="exploreButton" styleClass="ghost-nav-button" text="☰ Explore" />

            <Region HBox.hgrow="ALWAYS" />

            <HBox fx:id="searchContainer" alignment="CENTER_LEFT" maxWidth="420.0" prefHeight="46.0" prefWidth="331.0" spacing="8.0" styleClass="search-bar">
                <Label prefHeight="26.0" prefWidth="22.0" styleClass="search-icon" text="⌕" />
                <TextField fx:id="searchBar" prefHeight="29.0" prefWidth="279.0" promptText="Search auctions, brands, or categories..." styleClass="search-field" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" spacing="24.0">
                <HBox alignment="CENTER_LEFT" spacing="18.0">
                    <Button fx:id="logoutLinkButton" managed="false" styleClass="top-link" text="Logout" visible="false" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Button fx:id="logoutButton" styleClass="ghost-nav-button" text="Logout" />
                    <StackPane fx:id="avatarContainer" onMouseClicked="#handleAvatarClick" prefHeight="40.0" prefWidth="40.0" styleClass="avatar-circle">
                        <ImageView fx:id="avatarImageView" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="false" visible="false" />
                        <Label fx:id="avatarText" styleClass="avatar-text" text="U" />
                    </StackPane>
                </HBox>
            </HBox>
        </HBox>

        <AnchorPane fx:id="sidebarLayer" pickOnBounds="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="78.0">
            <children>
                <Region fx:id="sidebarOverlay" onMouseClicked="#handleOverlayClick" styleClass="sidebar-overlay" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

                <VBox fx:id="sidebarContent" minWidth="320.0" prefWidth="340.0" spacing="20.0" styleClass="side-bar" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <padding>
                        <Insets bottom="24.0" left="0.0" right="0.0" top="24.0" />
                    </padding>

                    <VBox alignment="CENTER" spacing="2.0" styleClass="sidebar-brand-box">
                        <padding>
                            <Insets bottom="0.0" left="24.0" right="24.0" top="0.0" />
                        </padding>
                        <ImageView fitHeight="96.0" fitWidth="96.0" pickOnBounds="true" preserveRatio="true" smooth="true">
                            <image>
                                <Image url="@../../images/bidify-logo-sidebar.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="sidebar-subtitle" text="Bid Smart - Win Fast" />
                    </VBox>

                    <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="0.0" left="16.0" right="16.0" top="0.0" />
                        </padding>
                        <Button fx:id="auctionsButton" styleClass="side-nav-button-active" text="Home " />
                        
                        <VBox spacing="2.0">
                            <Button fx:id="myAccountButton" maxWidth="Infinity" onAction="#handleAccountToggle" styleClass="side-nav-button" text="My Account" />
                            <VBox fx:id="accountSubMenu" managed="false" spacing="2.0" visible="false">
                                <padding>
                                    <Insets left="20.0" />
                                </padding>
                                <Button fx:id="profileButton" maxWidth="Infinity" onAction="#handleSidebarClick" styleClass="side-nav-sub-button" text="• Profile" />
                                <Button fx:id="inventoryButton" maxWidth="Infinity" styleClass="side-nav-sub-button" text="• Inventory" />
                                <Button maxWidth="Infinity" onAction="#handleSidebarClick" styleClass="side-nav-sub-button" text="• Settings" />
                                <Button fx:id="walletButton" maxWidth="Infinity" styleClass="side-nav-sub-button" text="• Wallet" />
                            </VBox>
                        </VBox>

                        <VBox spacing="2.0">
                            <Button fx:id="myActivitiesButton" maxWidth="Infinity" onAction="#handleActivitiesToggle" styleClass="side-nav-button" text="My Activities" />
                            <VBox fx:id="myActivitiesSubMenu" managed="false" spacing="2.0" visible="false">
                                <padding>
                                    <Insets left="20.0" />
                                </padding>
                                <Button fx:id="historyButton" maxWidth="Infinity" styleClass="side-nav-sub-button" text="• History" />
                                <Button fx:id="settlementsButton" maxWidth="Infinity" styleClass="side-nav-sub-button" text="• Settlements" />
                                <Button fx:id="myAuctionsButton" maxWidth="Infinity" styleClass="side-nav-sub-button" text="• My Auctions" />
                                <Button fx:id="createAuctionButton" maxWidth="Infinity" styleClass="side-nav-sub-button" text="• Create Auctions" />
                            </VBox>
                        </VBox>

                        <Button fx:id="adminUsersButton" managed="false" maxWidth="Infinity" styleClass="side-nav-button" text="Admin Users" visible="false" />
                        <Button fx:id="adminWalletRequestsButton" managed="false" maxWidth="Infinity" styleClass="side-nav-button" text="Wallet Requests" visible="false" />
                        <Button fx:id="adminAuctionsButton" managed="false" maxWidth="Infinity" styleClass="side-nav-button" text="Auction Management" visible="false" />
                    </VBox>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>
