<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="historyRoot" stylesheets="@../css/history.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.HistoryController">

    <center>
        <ScrollPane fx:id="historyScrollPane" fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="48" styleClass="main-content">

                <!-- Page Header -->
                <VBox spacing="8">
                    <Label styleClass="page-title" text="History" />
                    <Label styleClass="text-on-surface-variant" text="Review your bidding activity and transaction history." wrapText="true" />
                </VBox>

                <!-- Bidding Activity Section -->
                <VBox spacing="24">
                    <BorderPane>
                        <left>
                            <VBox spacing="4">
                                <Label styleClass="section-title" text="Bidding Activity" />
                                <Pane styleClass="title-underline" />
                            </VBox>
                        </left>
                        <right>
                            <HBox spacing="8" />
                        </right>
                    </BorderPane>

                    <HBox spacing="16">
                        <VBox spacing="12" styleClass="analytics-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label styleClass="table-header-text" text="MONEY FLOW" />
                                    <Label fx:id="moneyFlowMetricLabel" styleClass="analytics-value" text="\$0.00" wrapText="true" />
                                    <Label fx:id="moneyFlowTrendLabel" styleClass="analytics-trend-neutral" text="No movement yet" wrapText="true" />
                                </VBox>
                                <Label styleClass="analytics-symbol analytics-symbol-blue" text="\$" />
                            </HBox>
                            <StackPane fx:id="moneyFlowChartHost" minHeight="220.0" prefHeight="220.0" styleClass="analytics-chart-host" />
                            <Label fx:id="moneyFlowChartStateLabel" managed="false" styleClass="analytics-empty-text" text="No transaction history yet." visible="false" wrapText="true" />
                        </VBox>

                        <VBox spacing="12" styleClass="analytics-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label styleClass="table-header-text" text="BIDDING ACTIVITY" />
                                    <Label fx:id="biddingActivityMetricLabel" styleClass="analytics-value" text="0 bids" wrapText="true" />
                                    <Label fx:id="biddingActivityTrendLabel" styleClass="analytics-trend-neutral" text="No activity yet" wrapText="true" />
                                </VBox>
                                <Label styleClass="analytics-symbol analytics-symbol-green" text="↗" />
                            </HBox>
                            <StackPane fx:id="biddingActivityChartHost" minHeight="220.0" prefHeight="220.0" styleClass="analytics-chart-host" />
                            <Label fx:id="biddingActivityChartStateLabel" managed="false" styleClass="analytics-empty-text" text="No bid history yet." visible="false" wrapText="true" />
                        </VBox>
                    </HBox>

                    <VBox fx:id="biddingActivityContainer" styleClass="table-container">
                        <!-- Table Header -->
                        <HBox styleClass="table-header">
                            <Label minWidth="260.0" styleClass="table-header-text" text="AUCTION ITEM" HBox.hgrow="ALWAYS" />
                            <Label minWidth="150.0" styleClass="table-header-text" text="BID AMOUNT" />
                            <Label minWidth="180.0" styleClass="table-header-text" text="DATE &amp; TIME" />
                            <Label minWidth="120.0" styleClass="table-header-text" text="STATUS" />
                        </HBox>

                    </VBox>
                </VBox>

                <!-- Transaction Records Section -->
                <VBox spacing="24">
                    <BorderPane>
                        <left>
                            <VBox spacing="4">
                                <Label styleClass="section-title" text="Transaction Records" />
                                <Pane styleClass="title-underline" />
                            </VBox>
                        </left>
                    </BorderPane>

                    <VBox fx:id="transactionRecordsContainer" spacing="16">
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
