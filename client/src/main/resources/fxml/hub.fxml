<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1280.0" styleClass="root-bg" stylesheets="@../css/hub.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.HubController">

    <BorderPane prefHeight="800.0" prefWidth="1280.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll" vbarPolicy="AS_NEEDED">
                <content>
                    <VBox spacing="24.0" styleClass="content-area">
                        <padding>
                            <Insets bottom="36.0" left="40.0" right="40.0" top="36.0" />
                        </padding>

                        <HBox alignment="BOTTOM_LEFT">
                            <VBox fx:id = "header" spacing="8.0">
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <Label styleClass="live-dot" text="●" />
                                    <Label styleClass="eyebrow" text="REAL-TIME FLOOR" />
                                </HBox>
                                <Label fx:id="pageTitle" styleClass="page-title" text="Live Running Auctions" />
                            </VBox>

                            <Region HBox.hgrow="ALWAYS" />

                            <HBox spacing="8.0">
                                <Button styleClass="view-toggle-active" text="▦" />
                                <Button styleClass="view-toggle" text="☰" />
                            </HBox>
                        </HBox>

                        <Label fx:id="emptyStateLabel" managed="false" styleClass="empty-state-label" text="No live auctions right now." visible="false" />

                        <VBox fx:id="liveAuctionsContainer" spacing="24.0" />
                    </VBox>
                </content>
            </ScrollPane>
        </center>
    </BorderPane>

    <Button styleClass="fab" text="💬" AnchorPane.bottomAnchor="32.0" AnchorPane.rightAnchor="32.0" />
</AnchorPane>
