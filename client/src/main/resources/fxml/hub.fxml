<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" styleClass="root-bg" stylesheets="@../css/hub.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.HubController">

    <BorderPane prefHeight="720.0" prefWidth="1280.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll" vbarPolicy="AS_NEEDED">
                <content>
                    <VBox spacing="28.0" styleClass="content-area">
                        <padding>
                            <Insets bottom="36.0" left="40.0" right="40.0" top="36.0" />
                        </padding>

                        <HBox alignment="BOTTOM_LEFT">
                            <VBox spacing="8.0">
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <Label styleClass="live-dot" text="●" />
                                    <Label styleClass="eyebrow" text="REAL-TIME FLOOR" />
                                </HBox>
                                <Label styleClass="page-title" text="Auction Hub" />
                            </VBox>
                        </HBox>

                        <VBox fx:id="defaultSections" spacing="28.0">
                            <children>
                                <VBox spacing="14.0" styleClass="hub-section">
                                    <children>
                                        <BorderPane>
                                            <left>
                                                <VBox spacing="4.0">
                                                    <children>
                                                        <Label styleClass="section-title" text="Live Auctions" />
                                                        <Label styleClass="section-subtitle" text="Currently running auctions." />
                                                    </children>
                                                </VBox>
                                            </left>
                                            <right>
                                                <HBox alignment="CENTER_RIGHT" spacing="8.0" styleClass="sort-wrap">
                                                    <children>
                                                        <Label styleClass="sort-label" text="Sort by" />
                                                        <ComboBox fx:id="liveSortComboBox" onAction="#handleLiveSortChanged" styleClass="sort-combo-box" />
                                                    </children>
                                                </HBox>
                                            </right>
                                        </BorderPane>

                                        <Label fx:id="liveEmptyStateLabel" managed="false" styleClass="empty-state-label" text="No live auctions right now." visible="false" />

                                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="row-nav-wrap">
                                            <Button fx:id="liveScrollLeftButton" mnemonicParsing="false" onAction="#scrollLiveLeft" styleClass="row-nav-button" text="&lt;" />

                                            <ScrollPane fx:id="liveAuctionsScrollPane" fitToHeight="true" fitToWidth="false" hbarPolicy="AS_NEEDED" pannable="true" styleClass="row-scroll" vbarPolicy="NEVER" HBox.hgrow="ALWAYS">
                                                <content>
                                                    <HBox fx:id="liveAuctionsContainer" alignment="CENTER_LEFT" spacing="24.0" styleClass="auction-row" />
                                                </content>
                                            </ScrollPane>

                                            <Button fx:id="liveScrollRightButton" mnemonicParsing="false" onAction="#scrollLiveRight" styleClass="row-nav-button" text="&gt;" />
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="14.0" styleClass="hub-section">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label styleClass="section-title" text="Upcoming Auctions" />
                                                <Label styleClass="section-subtitle" text="Scheduled auctions that will start soon." />
                                            </children>
                                        </VBox>

                                        <Label fx:id="upcomingEmptyStateLabel" managed="false" styleClass="empty-state-label" text="No upcoming auctions right now." visible="false" />

                                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="row-nav-wrap">
                                            <Button fx:id="upcomingScrollLeftButton" mnemonicParsing="false" onAction="#scrollUpcomingLeft" styleClass="row-nav-button" text="&lt;" />

                                            <ScrollPane fx:id="upcomingAuctionsScrollPane" fitToHeight="true" fitToWidth="false" hbarPolicy="AS_NEEDED" pannable="true" styleClass="row-scroll" vbarPolicy="NEVER" HBox.hgrow="ALWAYS">
                                                <content>
                                                    <HBox fx:id="upcomingAuctionsContainer" alignment="CENTER_LEFT" spacing="24.0" styleClass="auction-row" />
                                                </content>
                                            </ScrollPane>

                                            <Button fx:id="upcomingScrollRightButton" mnemonicParsing="false" onAction="#scrollUpcomingRight" styleClass="row-nav-button" text="&gt;" />
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox fx:id="searchSection" managed="false" spacing="14.0" visible="false">
                            <children>
                                <BorderPane>
                                    <left>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label fx:id="searchTitleLabel" styleClass="section-title" text="Search Results" />
                                                <Label styleClass="section-subtitle" text="Matching live and upcoming auctions." />
                                            </children>
                                        </VBox>
                                    </left>
                                    <right>
                                        <HBox alignment="CENTER_RIGHT" spacing="8.0" styleClass="sort-wrap">
                                            <children>
                                                <Label styleClass="sort-label" text="Sort by" />
                                                <ComboBox fx:id="searchSortComboBox" onAction="#handleSearchSortChanged" styleClass="sort-combo-box" />
                                            </children>
                                        </HBox>
                                    </right>
                                </BorderPane>

                                <Label fx:id="searchEmptyStateLabel" managed="false" styleClass="empty-state-label" text="No auctions found." visible="false" />

                                <HBox fx:id="searchResultsContainer" spacing="24.0" styleClass="results-wrap" />
                            </children>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </center>
    </BorderPane>

    <Button styleClass="fab" text="💬" AnchorPane.bottomAnchor="32.0" AnchorPane.rightAnchor="32.0" />
</AnchorPane>
