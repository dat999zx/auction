                                    </image>
                                </ImageView>

                                <VBox alignment="CENTER" spacing="6.0">
                                    <Label styleClass="upload-icon" text="📷" />
                                    <Label styleClass="upload-title" text="Drop images here or click to upload" />
                                    <Label styleClass="upload-subtitle" text="SVG, PNG, JPG or GIF (max. 10MB)" />
                                </VBox>
                            </StackPane>

                            <FlowPane hgap="12.0" maxWidth="Infinity" prefWrapLength="400.0" vgap="12.0">
                                <StackPane prefHeight="84.0" prefWidth="84.0" styleClass="preview-tile">
                                    <ImageView fitHeight="84.0" fitWidth="84.0" preserveRatio="false">
                                        <image>
                                            <Image url="https://lh3.googleusercontent.com/aida-public/AB6AXuAK7b94xkE921VTFWMqcevwzzbpE7er4tXwxtQDefJ6yF7-hrJ3G0_4DoXbjQ01E2nnVYiw5owALL3hmE5U3MpmL82ZDm7JZHj6mpnSDTLC2MLjijVtEH6r2sow4T6OsdasT_Y5YMw0Ige-j5_nLIp-EIKl0FmPeMm7LWNh5TfZyhaKTdyRd6-NYBkSIlb-UhKk6gqQVROoO4g1wz81Ivyyp0_wdW7RSMG4-YKyXI91DFq3T2z8XysINW3U2n7FR1nJ8EzAtp4-KQs" />
                                        </image>
                                    </ImageView>
                                    <Button mnemonicParsing="false" styleClass="remove-image-button" text="x" StackPane.alignment="TOP_RIGHT" />
                                </StackPane>

                                <StackPane prefHeight="84.0" prefWidth="84.0" styleClass="empty-preview-tile">
                                    <Label styleClass="empty-preview-icon" text="🖼" />
                                </StackPane>
                            </FlowPane>
                        </VBox>
                        <rowConstraints>
                            <RowConstraints />
                        </rowConstraints>
                    </GridPane>

                    <GridPane hgap="24.0" maxWidth="Infinity" minWidth="0.0">
                        <columnConstraints>
                            <ColumnConstraints maxWidth="320.0" minWidth="320.0" prefWidth="320.0" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="0.0" />
                        </columnConstraints>

                        <VBox spacing="8.0" GridPane.columnIndex="0">
                            <Label styleClass="section-title" text="Auction Economics" />
                            <Label styleClass="section-description" text="Define the financial parameters and duration of the event." wrapText="true" />
                        </VBox>

                        <VBox maxWidth="Infinity" minWidth="0.0" spacing="12.0" GridPane.columnIndex="1">
                            <GridPane hgap="16.0" maxWidth="Infinity" minWidth="0.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50.0" />
                                    <ColumnConstraints percentWidth="50.0" />
                                </columnConstraints>

                                <VBox spacing="6.0" GridPane.columnIndex="0">
                                    <Label styleClass="field-label" text="STARTING PRICE (USD)" />
                                    <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="input-wrapper">
                                        <Label styleClass="currency-label" text="\$" />
                                        <TextField fx:id="startingPriceField" promptText="0.00" styleClass="embedded-input" HBox.hgrow="ALWAYS" />
                                    </HBox>
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="1">
                                    <Label styleClass="field-label" text="START DATE" />
                                    <DatePicker fx:id="endDatePicker" maxWidth="Infinity" prefHeight="47.0" prefWidth="442.0" styleClass="date-picker-modern" />
                                </VBox>
                                <rowConstraints>
                                    <RowConstraints />
                                </rowConstraints>
                            </GridPane>

                            <GridPane hgap="16.0" maxWidth="Infinity" minWidth="0.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50.0" />
                                    <ColumnConstraints percentWidth="50.0" />
                                </columnConstraints>

                                <VBox spacing="6.0" GridPane.columnIndex="0">
                                    <Label styleClass="field-label" text="MIN INCREMENT" />
                                    <TextField fx:id="minIncrementField" promptText="0" styleClass="text-field-modern" text="0" />
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="1">
                                    <Label styleClass="field-label" text="END DATE" />
                           <DatePicker fx:id="endDatePicker1" maxWidth="Infinity" styleClass="date-picker-modern" />
                                </VBox>
                                <rowConstraints>
                                    <RowConstraints />
                                </rowConstraints>
                            </GridPane>
                        </VBox>
                        <rowConstraints>
                            <RowConstraints />
                        </rowConstraints>
                    </GridPane>

                    <Separator />

                    <HBox alignment="CENTER_RIGHT" spacing="12.0">
                        <Button mnemonicParsing="false" styleClass="primary-button-large" text="Create Auction" />
                    </HBox>

                    <Label styleClass="footer-label" text="© 2024 BIDIFY PREMIUM AUCTIONEERING ECOSYSTEM. ALL LISTINGS SUBJECT TO CURATOR VERIFICATION." wrapText="true" />
               <VBox layoutX="34.0" layoutY="30.0" spacing="4.0">
                  <children>
                     <Label styleClass="page-title" text="Create New Auction" />
                     <Label styleClass="page-subtitle" text="List your premium asset on the global stage." />
                  </children>
               </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
