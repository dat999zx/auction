<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="1080.0" prefWidth="1920.0" styleClass="create-auction-root" stylesheets="@../css/create-auction.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.CreateAuctionController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="24.0" styleClass="top-bar">
            <padding>
                <Insets bottom="16.0" left="32.0" right="32.0" top="16.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="0.1">
            <ImageView fitHeight="27.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/left-arrow%20(1).png" />
               </image>
            </ImageView>
                <Button fx:id="exploreButton" onAction="#toggleSidebar" styleClass="ghost-nav-button" text="☰ Explore" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" spacing="24.0">
                <HBox alignment="CENTER_LEFT" spacing="18.0">
                    <Button fx:id="auctionsButton" onAction="#handleSelection" styleClass="top-link" text="Auctions" />
                    <Button fx:id="createAuctionButton" onAction="#handleSelection" styleClass="top-link-active" text="Create Auction" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Button onAction="#handleLogout" styleClass="ghost-nav-button" text="Logout" />
                    <Button styleClass="icon-button" text="🔔" />
                    <StackPane prefHeight="40.0" prefWidth="40.0" styleClass="avatar-circle">
                        <Label styleClass="avatar-text" text="U" />
                    </StackPane>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <StackPane fx:id="sidebarContainer" maxWidth="250.0" minWidth="250.0" prefWidth="250.0">
            <VBox fx:id="sidebarContent" prefWidth="250.0" spacing="20.0" styleClass="side-bar">
                <padding>
                    <Insets bottom="24.0" left="0.0" right="0.0" top="24.0" />
                </padding>

                <VBox alignment="CENTER" spacing="2.0" styleClass="sidebar-brand-box">
                    <padding>
                        <Insets bottom="0.0" left="24.0" right="24.0" top="0.0" />
                    </padding>
                    <Label styleClass="sidebar-brand" text="BIDIFY" />
                    <Label styleClass="sidebar-subtitle" text="Bid Smart - Win Fast" />
                </VBox>

                <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                    <Button styleClass="side-nav-button-active" text="Live Auctions" />
                    <Button styleClass="side-nav-button" text="Upcoming" />
                    <Button styleClass="side-nav-button" text="Ended" />
                    <Button styleClass="side-nav-button" text="My Bids" />
                    <Button styleClass="side-nav-button" text="Watchlist" />
                </VBox>

                <VBox>
                    <padding>
                        <Insets bottom="0.0" left="24.0" right="24.0" top="0.0" />
                    </padding>
                    <Button styleClass="primary-gradient-button" text="Place a Consignment" />
                </VBox>
            </VBox>
        </StackPane>
    </left>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" pannable="false" styleClass="content-scroll" vbarPolicy="AS_NEEDED">
            <content>
                <VBox fillWidth="true" maxWidth="Infinity" minWidth="0.0" spacing="16.0" styleClass="content-wrapper">
                    <padding>
                        <Insets bottom="18.0" left="24.0" right="24.0" top="20.0" />
                    </padding>

                    <VBox spacing="4.0">
                        <Label styleClass="page-title" text="Create New Auction" />
                        <Label styleClass="page-subtitle" text="List your premium asset on the global stage." />
                    </VBox>

                    <GridPane hgap="24.0" maxWidth="Infinity" minWidth="0.0">
                        <columnConstraints>
                            <ColumnConstraints maxWidth="320.0" minWidth="320.0" prefWidth="320.0" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="0.0" />
                        </columnConstraints>

                        <VBox spacing="8.0" GridPane.columnIndex="0">
                            <Label styleClass="section-title" text="Asset Details" />
                            <Label styleClass="section-description" text="Provide the essential information about your item." wrapText="true" />
                        </VBox>

                        <VBox maxWidth="Infinity" minWidth="0.0" spacing="12.0" GridPane.columnIndex="1">
                            <VBox spacing="6.0">
                                <Label styleClass="field-label" text="PRODUCT NAME" />
                                <TextField fx:id="productNameField" promptText="e.g. 1963 Vintage Chronograph" styleClass="text-field-modern" />
                            </VBox>

                            <VBox spacing="6.0">
                                <Label styleClass="field-label" text="DESCRIPTION" />
                                <TextArea fx:id="descriptionArea" prefRowCount="3" promptText="Detail the provenance, condition, and unique features..." styleClass="text-area-modern" wrapText="true" />
                            </VBox>

                            <GridPane hgap="16.0" maxWidth="Infinity" minWidth="0.0">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50.0" />
                                    <ColumnConstraints percentWidth="50.0" />
                                </columnConstraints>

                                <VBox spacing="6.0" GridPane.columnIndex="0">
                                    <Label styleClass="field-label" text="CATEGORY" />
                                    <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" promptText="Select category" styleClass="combo-box-modern" />
                                </VBox>

                                <VBox spacing="6.0" GridPane.columnIndex="1">
                                    <Label styleClass="field-label" text="PRODUCT TYPE" />
                                    <ComboBox fx:id="productTypeComboBox" maxWidth="Infinity" promptText="Select type" styleClass="combo-box-modern" />
                                </VBox>
                                <rowConstraints>
                                    <RowConstraints />
                                </rowConstraints>
                            </GridPane>
                        </VBox>
                        <rowConstraints>
                            <RowConstraints />
                        </rowConstraints>
                    </GridPane>

                    <GridPane hgap="24.0" maxWidth="Infinity" minWidth="0.0">
                        <columnConstraints>
                            <ColumnConstraints maxWidth="320.0" minWidth="320.0" prefWidth="320.0" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="0.0" />
                        </columnConstraints>

                        <VBox spacing="8.0" GridPane.columnIndex="0">
                            <Label styleClass="section-title" text="Media Gallery" />
                            <Label styleClass="section-description" text="High-resolution imagery increases final bid values by up to 40%." wrapText="true" />
                        </VBox>

                        <VBox maxWidth="Infinity" minWidth="0.0" spacing="12.0" GridPane.columnIndex="1">
                            <StackPane maxWidth="Infinity" prefHeight="130.0" styleClass="upload-box">
                                <ImageView fitHeight="130.0" opacity="0.10" preserveRatio="false">
