<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="row" alignment="CENTER_LEFT" styleClass="table-row" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.history.BiddingRowController">
    <HBox spacing="16" alignment="CENTER_LEFT" prefWidth="320">
        <Pane prefWidth="48" prefHeight="48" styleClass="image-placeholder"/>
        <VBox spacing="4">
            <Label fx:id="titleLabel" styleClass="text-primary, table-row-title"/>
            <Label fx:id="subtitleLabel" styleClass="text-on-surface-variant, table-row-subtitle"/>
        </VBox>
    </HBox>
    <Label fx:id="amountLabel" prefWidth="180" styleClass="text-secondary, table-row-amount"/>
    <Label fx:id="dateLabel" prefWidth="240" styleClass="text-on-surface-variant"/>
    <HBox fx:id="statusBox" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
        <Label fx:id="statusLabel"/>
    </HBox>
</HBox>
