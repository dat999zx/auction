<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1280.0" styleClass="root-bg" stylesheets="@../css/hub.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bidify.controller.HubController">

    <BorderPane prefHeight="800.0" prefWidth="1280.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="24.0" styleClass="top-bar">
                <padding>
                    <Insets bottom="16.0" left="32.0" right="32.0" top="16.0" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="16.0">
                    <Button fx:id="exploreButton" onAction="#toggleSidebar" styleClass="ghost-nav-button" text="☰ Explore" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" maxWidth="420.0" prefHeight="46.0" prefWidth="331.0" spacing="8.0" styleClass="search-bar">
                    <Label styleClass="search-icon" text="⌕" />
                    <TextField fx:id="searchBar" promptText="Search auctions, brands, or categories..." styleClass="search-field" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" spacing="24.0">
                    <HBox alignment="CENTER_LEFT" spacing="18.0">
                        <Button fx:id="auctionsButton" onAction="#handleSelection" styleClass="top-link-active" text="Auctions" />
                        <Button fx:id="createAuctionButton" onAction="#handleSelection" styleClass="top-link" text="Create Auction" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <Button onAction="#handleLogout" styleClass="ghost-nav-button" text="Logout" />
                        <Button styleClass="icon-button" text="🔔" />
                        <Button styleClass="icon-button" text="⟲" />
                        <StackPane prefHeight="40.0" prefWidth="40.0" styleClass="avatar-circle">
                            <Label styleClass="avatar-text" text="U" />
                        </StackPane>
                    </HBox>
                </HBox>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scroll" vbarPolicy="AS_NEEDED">
                <content>
                    <VBox spacing="24.0" styleClass="content-area">
                        <padding>
                            <Insets bottom="36.0" left="40.0" right="40.0" top="36.0" />
                        </padding>

                        <HBox alignment="BOTTOM_LEFT">
                            <VBox spacing="8.0">
                                <HBox alignment="CENTER_LEFT" spacing="8.0">
                                    <Label styleClass="live-dot" text="●" />
                                    <Label styleClass="eyebrow" text="REAL-TIME FLOOR" />
                                </HBox>
                                <Label styleClass="page-title" text="Live Running Auctions" />
                            </VBox>

                            <Region HBox.hgrow="ALWAYS" />

                            <HBox spacing="8.0">
                                <Button styleClass="view-toggle-active" text="▦" />
                                <Button styleClass="view-toggle" text="☰" />
                            </HBox>
                        </HBox>

                        <Label fx:id="emptyStateLabel" managed="false" styleClass="empty-state-label" text="No live auctions right now." visible="false" />

                        <VBox fx:id="liveAuctionsContainer" spacing="24.0" />
                    </VBox>
                </content>
            </ScrollPane>
        </center>
    </BorderPane>

    <fx:include fx:id="sharedSidebar" source="common-sidebar.fxml" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="78.0" />

    <Button styleClass="fab" text="💬" AnchorPane.bottomAnchor="32.0" AnchorPane.rightAnchor="32.0" />
</AnchorPane>
